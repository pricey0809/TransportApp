# NHVR API — subscription key from api-portal.nhvr.gov.au > Profile > Subscriptions
NHVR_API_KEY=your_subscription_key_here

# API gateway base URL (confirmed: https://api-public.nhvr.gov.au)
NHVR_API_BASE_URL=https://api-public.nhvr.gov.au

# Flask
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=true

# Valhalla routing engine
# Local (Docker):  VALHALLA_URL=http://localhost:8002
# Cloud road test: VALHALLA_URL=https://valhalla.openstreetmap.de
VALHALLA_URL=http://localhost:8002
